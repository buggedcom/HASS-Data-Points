{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["custom_components/hass_datapoints/src/*"]
    }
  },
  "include": [
    "custom_components/hass_datapoints/src/**/*.ts",
    "eslint.config.mjs",
    "prettier.config.cjs"
  ],
  "exclude": [
    "custom_components/hass_datapoints/hass-datapoints-cards.js",
    "custom_components/hass_datapoints/src/**/__tests__/**",
    "node_modules"
  ]
}
