{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"]
  },
  "include": [
    "custom_components/hass_datapoints/src/**/*.js",
    "eslint.config.mjs",
    "prettier.config.cjs"
  ],
  "exclude": [
    "custom_components/hass_datapoints/hass-datapoints-cards.js",
    "custom_components/hass_datapoints/src/**/__tests__/**",
    "custom_components/hass_datapoints/src/lib/__tests__/load-legacy-script.ts",
    "node_modules"
  ]
}
