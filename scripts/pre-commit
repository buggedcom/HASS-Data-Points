#!/usr/bin/env bash
#
# pre-commit hook:
#  1. Format all staged Prettier-supported files (ts, js, md, json, css, html…)
#  2. Lint & format staged Python files with ruff
#  3. Lint package.json version specifiers when package metadata changes
#  4. Validate TypeScript types when frontend sources/config change
#  5. Rebuild hass-datapoints-cards.js when any src/ file is staged
#
# Install:  pnpm hooks:install
#           (or manually: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit)
#
# Python linting requires ruff: pip install -r requirements_dev.txt

set -euo pipefail

SRC_DIR="custom_components/hass_datapoints/src"
OUT_FILE="custom_components/hass_datapoints/hass-datapoints-cards.js"

# Extensions Prettier handles in this repo
PRETTIER_EXTS="ts|js|mjs|cjs|css|html|json|md|yaml|yml"

# Staged files that Prettier should format
STAGED_PRETTIER=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E "\.(${PRETTIER_EXTS})$" || true)

# Staged Python files
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E "\.py$" || true)

# Staged files under src/ that trigger a bundle rebuild
STAGED_SRC=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep "^$SRC_DIR/" || true)

# Staged frontend/config files that should trigger a type check
STAGED_TYPECHECK=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E "^(custom_components/hass_datapoints/src/.*\\.(ts|js)|tsconfig.*\\.json|package\\.json)$" || true)

# Staged package metadata files that should trigger package.json linting
STAGED_PACKAGE_JSON=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E "^package\\.json$" || true)

if [ -z "$STAGED_PRETTIER" ] && [ -z "$STAGED_PY" ] && [ -z "$STAGED_SRC" ] && [ -z "$STAGED_TYPECHECK" ] && [ -z "$STAGED_PACKAGE_JSON" ]; then
  exit 0
fi

# ── 1. Format with Prettier ────────────────────────────────────────────────────
if [ -n "$STAGED_PRETTIER" ]; then
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "[pre-commit] pnpm is required for Prettier." >&2
    exit 1
  fi
  echo "[pre-commit] Formatting staged files with Prettier and Eslint…"
  echo "$STAGED_PRETTIER" | xargs pnpm format --
  # Re-stage any files Prettier modified
  echo "$STAGED_PRETTIER" | xargs git add
fi

# ── 2. Lint & format Python with ruff ─────────────────────────────────────────
if [ -n "$STAGED_PY" ]; then
  # Prefer the venv ruff, fall back to whatever is on PATH
  REPO_ROOT="$(git rev-parse --show-toplevel)"
  RUFF="${REPO_ROOT}/.venv/bin/ruff"
  if [ ! -x "$RUFF" ]; then
    RUFF="$(command -v ruff || true)"
  fi
  if [ -z "$RUFF" ]; then
    echo "[pre-commit] ruff not found — install with: pnpm py:install" >&2
    exit 1
  fi
  echo "[pre-commit] Linting staged Python files with ruff…"
  # Auto-fix safe lint issues, then format
  echo "$STAGED_PY" | xargs "$RUFF" check --fix --
  echo "$STAGED_PY" | xargs "$RUFF" format --
  # Re-stage any files ruff modified
  echo "$STAGED_PY" | xargs git add
fi

# ── 3. Lint package.json versions ──────────────────────────────────────────────
if [ -n "$STAGED_PACKAGE_JSON" ]; then
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "[pre-commit] pnpm is required to lint package.json." >&2
    exit 1
  fi
  echo "[pre-commit] Linting package.json versions…"
  pnpm lint:package-json
fi

# ── 4. Validate frontend types ─────────────────────────────────────────────────
if [ -n "$STAGED_TYPECHECK" ]; then
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "[pre-commit] pnpm is required to validate TypeScript types." >&2
    exit 1
  fi
  echo "[pre-commit] Validating TypeScript types…"
  pnpm lint:types
fi

# ── 5. Rebuild the bundle ──────────────────────────────────────────────────────
if [ -n "$STAGED_SRC" ]; then
  if ! command -v pnpm >/dev/null 2>&1; then
    echo "[pre-commit] pnpm is required to build frontend assets." >&2
    exit 1
  fi
  echo "[pre-commit] src/ files changed — rebuilding $OUT_FILE…"
  pnpm build
  git add "$OUT_FILE"
  echo "[pre-commit] ✓ $OUT_FILE rebuilt and staged"
fi
