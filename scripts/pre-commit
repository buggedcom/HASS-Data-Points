#!/usr/bin/env bash
#
# pre-commit hook: rebuild hass-datapoints-cards.js when any src/ file is staged.
#
# Install:  pnpm hooks:install
#           (or manually: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit)

set -euo pipefail

SRC_DIR="custom_components/hass_datapoints/src"
OUT_FILE="custom_components/hass_datapoints/hass-datapoints-cards.js"

# Check if any src/ JS files are staged
STAGED_SRC=$(git diff --cached --name-only --diff-filter=ACMR -- "$SRC_DIR/*.js" 2>/dev/null || true)

if [ -z "$STAGED_SRC" ]; then
  exit 0
fi

if ! command -v pnpm >/dev/null 2>&1; then
  echo "[pre-commit] pnpm is required to build frontend assets." >&2
  exit 1
fi

echo "[pre-commit] src/ files changed — rebuilding $OUT_FILE via pnpm …"

pnpm build

# Stage the rebuilt output so the commit includes it
git add "$OUT_FILE"

echo "[pre-commit] ✓ $OUT_FILE rebuilt and staged"
